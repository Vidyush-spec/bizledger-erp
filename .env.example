# ═══════════════════════════════════════════════════════════
# BIZLEDGER ENVIRONMENT VARIABLES
# Plain English: This file holds all the secret settings for
# your ERP. Think of it as the master key cabinet.
# NEVER commit this file to GitHub — keep it private always.
# ═══════════════════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────────────────
# Plain English: The address of your filing cabinet.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://bizledger:CHANGE_THIS_PASSWORD@localhost:5432/bizledger_db"

# ── JWT SECRETS ───────────────────────────────────────────
# Plain English: The master keys used to sign login tokens.
# Generate strong random strings — at least 64 characters.
# NEVER share these. If leaked, change them immediately (all users get logged out).
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING_eg_openssl_rand_hex_32"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING"
JWT_ACCESS_EXPIRES="15m"     # Access token expires in 15 minutes
JWT_REFRESH_EXPIRES="7d"     # Refresh token lasts 7 days

# ── ENCRYPTION ────────────────────────────────────────────
# Plain English: The key used to scramble sensitive data
# like PAN numbers and bank accounts before saving to database.
# Must be exactly 32 characters.
ENCRYPTION_KEY="REPLACE_WITH_EXACTLY_32_CHAR_KEY!!"

# ── SERVER ────────────────────────────────────────────────
PORT=3000
NODE_ENV="production"
# Your ERP's domain — where the frontend lives
FRONTEND_URL="https://yourdomain.com"

# ── RATE LIMITING ─────────────────────────────────────────
# Plain English: How many login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── EMAIL (for sending invoices, payslips, password resets) ─
# Using Resend — free for 3000 emails/month
RESEND_API_KEY="re_XXXXXXXXXXXX"
EMAIL_FROM="noreply@yourdomain.com"

# ── FILE STORAGE (Cloudflare R2 — first 10GB free) ────────
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY="your_r2_access_key"
R2_SECRET_KEY="your_r2_secret_key"
R2_BUCKET_NAME="bizledger-files"
R2_PUBLIC_URL="https://files.yourdomain.com"
